  "description": "Raw TCP HTTP/1.1 server built and maintained by Nishant Gaurav.",
  "author": "Nishant Gaurav <codewithevilxd@gmail.com> (https://nishantdev.space)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/tcpServer.ts",
    "start": "bun src/tcpServer.ts",
    "start:tcp": "bun src/tcpServer.ts",
